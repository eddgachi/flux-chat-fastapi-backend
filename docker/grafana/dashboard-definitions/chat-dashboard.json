    {
      "id": 10,
      "type": "timeseries",
      "title": "Celery Task Execution Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "flux-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "flux-prometheus" },
          "expr": "sum(rate(celery_tasks_total[1m])) by (task_name, status)",
          "legendFormat": "{{task_name}} — {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
